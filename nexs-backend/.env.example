# Napnix Admin Backend - Environment Variables

# ===========================================
# SERVER
# ===========================================
PORT=5000
NODE_ENV=production

# ===========================================
# DATABASE
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=napnix

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# AI PROVIDERS + TENANT KEY ENCRYPTION
# ===========================================
# Must match the tenant backend secret when both services read the same settings DB.
AI_SETTINGS_SECRET=replace-with-a-long-random-secret-for-ai-settings
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
GROK_API_KEY=

# ===========================================
# EMAIL (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SECURE=false
SMTP_FROM_NAME=Napnix
SMTP_FROM_EMAIL=noreply@napnix.in

# ===========================================
# CLOUDFLARE (for tenant provisioning)
# ===========================================
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_TUNNEL_ID=70213622-2764-420f-9b2f-ae92a525dc56
CF_CONFIG_PATH=/etc/cloudflared/config.yml

# ===========================================
# NEXCRM (Multi-tenant settings)
# ===========================================
NEXCRM_DOMAIN=napnix.in
NEXCRM_BACKEND_PATH=/var/www/html/nexcrm-backend
NEXCRM_PAGES_URL=nexcrm-frontend.pages.dev
NEXCRM_PAGES_PROJECT=nexcrm-frontend
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# ===========================================
# NAPNIX SUPER ADMIN (added to each tenant)
# ===========================================
NAPNIX_ADMIN_EMAIL=admin@napnix.in
NAPNIX_ADMIN_PASSWORD=Napnix@2024!

# ===========================================
# REGISTRY SERVICE (for mobile app lookup)
# ===========================================
REGISTRY_URL=https://registry.napnix.in
REGISTRY_API_KEY=your-registry-api-key

# ===========================================
# RAZORPAY (Billing)
# ===========================================
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ===========================================
# APP URLS
# ===========================================
APP_URL=https://admin.napnix.in
API_URL=https://api.napnix.in

# Notification Recipients (comma-separated)
NOTIFICATION_EMAILS=anu2614kumar@gmail.com,amankumar.sahani096@gmail.com

# ===========================================
# GOOGLE RECAPTCHA v3
# ===========================================
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ===========================================
# WHATSAPP SERVICE (nexs-whatsapp on port 5100)
# ===========================================
WHATSAPP_SERVICE_URL=http://localhost:5100
WHATSAPP_SERVICE_KEY=your-strong-random-key-same-as-nexs-whatsapp
# AES encryption key for Meta tokens stored in DB (defaults to JWT_SECRET if not set)
META_TOKEN_SECRET=your-meta-token-encryption-secret

# ===========================================
# SEO & SEARCH ENGINE INDEXING
# ===========================================
WEBSITE_URL=https://napnix.in
# IndexNow API key (auto-generated if empty, serves at /{key}.txt)
INDEXNOW_KEY=
# Google Indexing API (optional — service account JSON file path OR inline JSON)
GOOGLE_SERVICE_ACCOUNT_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON=
